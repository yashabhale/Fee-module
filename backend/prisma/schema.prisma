// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  ADMIN
  ACCOUNTANT
  STAFF
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum PaymentMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
  ONLINE
  DD
}

enum RefundMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
}

// ============ MODELS ============

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  phone         String      @unique
  password      String
  firstName     String
  lastName      String
  role          UserRole    @default(STAFF)
  departmentName String?
  isActive      Boolean     @default(true)
  lastLogin     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  feePayments   FeePayment[]
  refunds       RefundRequest[] @relation("ApprovedBy")
  createdRefunds RefundRequest[] @relation("CreatedBy")

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Parent {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?  @unique
  phone         String   @unique
  relationship  String?  // Father, Mother, Guardian
  occupation    String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  students      Student[]

  @@index([phone])
  @@index([email])
  @@index([city])
}

model Student {
  id            String      @id @default(cuid())
  studentId     String      @unique
  firstName     String
  lastName      String
  email         String?     @unique
  phone         String?
  dateOfBirth   DateTime?
  gender        String?

  // Address
  street        String?
  city          String?
  state         String?
  postalCode    String?
  country       String?

  // Enrollment
  courseId      String
  classId       String
  enrollmentDate DateTime
  status        StudentStatus @default(ACTIVE)
  isVerified    Boolean     @default(false)

  // Parent Info
  parentId      String?
  parent        Parent?     @relation(fields: [parentId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  course        Course      @relation(fields: [courseId], references: [id])
  class         Class       @relation(fields: [classId], references: [id])
  feePayments   FeePayment[]
  refunds       RefundRequest[]

  @@index([studentId])
  @@index([email])
  @@index([city])
  @@index([status])
  @@index([courseId])
  @@index([classId])
}

model Course {
  id            String   @id @default(cuid())
  name          String   @unique
  code          String   @unique
  description   String?
  durationValue Int?
  durationUnit  String?  // Years, Months
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  classes       Class[]
  feeStructures FeeStructure[]
  students      Student[]

  @@index([code])
  @@index([isActive])
}

model Class {
  id            String   @id @default(cuid())
  name          String
  code          String
  courseId      String
  semester      Int?
  capacity      Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  students      Student[]
  feeStructures FeeStructure[]

  @@unique([code, courseId])
  @@index([courseId])
  @@index([isActive])
}

model FeeType {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  feeStructures FeeStructureComponent[]

  @@index([isActive])
}

model FeeStructure {
  id            String      @id @default(cuid())
  courseId      String
  classId       String
  academicYear  String      // e.g., "2024-2025"
  totalFee      Decimal     @db.Decimal(10, 2)
  paymentTerms  String?     // Annually, Semi-annually, Quarterly, Monthly
  dueDate       DateTime?
  gracePeriodDays Int?      @default(15)
  penaltyPerDay Decimal?    @db.Decimal(5, 2) // Daily penalty amount
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  class         Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  components    FeeStructureComponent[]
  feePayments   FeePayment[]

  @@unique([courseId, classId, academicYear])
  @@index([courseId])
  @@index([classId])
  @@index([isActive])
}

model FeeStructureComponent {
  id            String   @id @default(cuid())
  feeStructureId String
  feeTypeId     String
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  feeStructure  FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeType       FeeType      @relation(fields: [feeTypeId], references: [id], onDelete: Cascade)

  @@unique([feeStructureId, feeTypeId])
  @@index([feeStructureId])
  @@index([feeTypeId])
}

model FeePayment {
  id            String      @id @default(cuid())
  studentId     String
  feeStructureId String
  totalAmount   Decimal     @db.Decimal(10, 2)
  amountPaid    Decimal     @db.Decimal(10, 2) @default(0)
  amountPending Decimal     @db.Decimal(10, 2)
  dueDate       DateTime
  paymentStatus PaymentStatus @default(PENDING)
  penaltyCharges Decimal?    @db.Decimal(10, 2) @default(0)
  discountAmount Decimal?    @db.Decimal(10, 2) @default(0)
  discountReason String?
  approvedBy    String?
  notes         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure  FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  approver      User?       @relation(fields: [approvedBy], references: [id])
  payments      Payment[]
  refunds       RefundRequest[]

  @@index([studentId])
  @@index([feeStructureId])
  @@index([paymentStatus])
  @@index([dueDate])
  @@index([createdAt])
}

model Payment {
  id            String      @id @default(cuid())
  feePaymentId  String
  amount        Decimal     @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  transactionId String?     // External payment gateway transaction ID
  receivedBy    String?     // User who recorded the payment
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  feePayment    FeePayment  @relation(fields: [feePaymentId], references: [id], onDelete: Cascade)

  @@index([feePaymentId])
  @@index([paymentMethod])
  @@index([createdAt])
}

model RefundRequest {
  id            String      @id @default(cuid())
  studentId     String
  feePaymentId  String
  amount        Decimal     @db.Decimal(10, 2)
  reason        String      // Reason for refund
  description   String?
  requestDate   DateTime    @default(now())
  status        RefundStatus @default(PENDING)
  approvedBy    String?
  approvalDate  DateTime?
  rejectionReason String?
  refundMethod  RefundMethod?
  bankAccountHolder String?
  bankAccountNumber String?
  ifscCode      String?
  processedDate DateTime?
  refundTransactionId String?
  notes         String?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feePayment    FeePayment  @relation(fields: [feePaymentId], references: [id], onDelete: Cascade)
  approver      User?       @relation("ApprovedBy", fields: [approvedBy], references: [id])
  creator       User?       @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([studentId])
  @@index([feePaymentId])
  @@index([status])
  @@index([requestDate])
}

model BulkUploadLog {
  id            String   @id @default(cuid())
  fileName      String
  totalRecords  Int
  successCount  Int
  failureCount  Int
  status        String   // PROCESSING, COMPLETED, FAILED
  errorDetails  String?
  uploadedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
